<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>fishtvlove - 打掉重練 IG 輪播 v2</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700&Noto+Sans+TC:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Noto Sans TC', sans-serif;
            background: #0F1419;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
        }

        .carousel-container {
            width: 100%;
            max-width: 540px;
            aspect-ratio: 4/5;
            position: relative;
            background: #0F1419;
            border-radius: 24px;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            border: 1px solid rgba(91, 158, 255, 0.1);
        }

        .carousel-wrapper {
            position: relative;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }

        .slide {
            position: absolute;
            width: 100%;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            padding: 60px 40px 80px;
            opacity: 0;
            transition: opacity 0.5s ease-in-out;
        }

        .slide.active {
            opacity: 1;
        }

        /* ===== SLIDE 1: HOOK ===== */
        .slide.slide-1 {
            background: linear-gradient(135deg, #0F1F3A 0%, #1a2a4a 50%, #0F1F3A 100%);
            justify-content: center;
            align-items: center;
            text-align: center;
        }

        .slide.slide-1 .slide-title {
            font-size: 80px;
            font-weight: 700;
            color: #5B9EFF;
            margin-bottom: 24px;
            font-family: 'Noto Serif TC', serif;
            letter-spacing: -2px;
            line-height: 1;
        }

        .slide.slide-1 .slide-subtitle {
            font-size: 18px;
            color: #E5E7EB;
            font-weight: 400;
            line-height: 1.6;
            font-family: 'Noto Sans TC', sans-serif;
            max-width: 280px;
            margin: 0 auto;
        }

        /* ===== SLIDE 2: CONTEXT ===== */
        .slide.slide-2 {
            background: linear-gradient(135deg, #1E3A5F 0%, #162A47 100%);
            justify-content: flex-start;
            padding-top: 80px;
        }

        .slide.slide-2 .slide-title {
            color: #5B9EFF;
            font-size: 40px;
            margin-bottom: 32px;
            font-family: 'Noto Serif TC', serif;
            font-weight: 700;
            line-height: 1.2;
        }

        .slide.slide-2 .slide-content {
            color: #D1D5DB;
            font-size: 16px;
            line-height: 1.8;
            font-family: 'Noto Sans TC', sans-serif;
            font-weight: 400;
        }

        .slide.slide-2 .content-line {
            margin-bottom: 16px;
        }

        /* ===== SLIDE 3: BUILD #1 ===== */
        .slide.slide-3 {
            background: linear-gradient(135deg, #1E3A5F 0%, #1a2f4a 100%);
            justify-content: flex-start;
            padding-top: 70px;
        }

        .slide.slide-3 .slide-title {
            color: #5B9EFF;
            font-size: 44px;
            margin-bottom: 36px;
            font-family: 'Noto Serif TC', serif;
            font-weight: 700;
            line-height: 1.2;
        }

        .slide.slide-3 .step {
            display: flex;
            align-items: flex-start;
            margin-bottom: 14px;
            color: #E5E7EB;
            font-size: 15px;
            line-height: 1.6;
            font-family: 'Noto Sans TC', sans-serif;
        }

        .slide.slide-3 .step-emoji {
            margin-right: 16px;
            font-size: 20px;
            min-width: 28px;
            flex-shrink: 0;
        }

        /* ===== SLIDE 4: BUILD #2 ===== */
        .slide.slide-4 {
            background: linear-gradient(135deg, #162A47 0%, #1E3A5F 100%);
            justify-content: flex-start;
            padding-top: 100px;
        }

        .slide.slide-4 .slide-title {
            color: #E5E7EB;
            font-size: 42px;
            margin-bottom: 32px;
            font-family: 'Noto Serif TC', serif;
            font-weight: 700;
            line-height: 1.2;
        }

        .slide.slide-4 .slide-content {
            color: #D1D5DB;
            font-size: 16px;
            line-height: 1.8;
            font-family: 'Noto Sans TC', sans-serif;
            font-weight: 400;
        }

        .slide.slide-4 .content-line {
            margin-bottom: 12px;
        }

        /* ===== SLIDE 5: TENSION ===== */
        .slide.slide-5 {
            background: linear-gradient(135deg, #1E3A5F 0%, #1a2a4a 100%);
            justify-content: flex-start;
            padding-top: 70px;
        }

        .slide.slide-5 .slide-title {
            color: #5B9EFF;
            font-size: 44px;
            margin-bottom: 32px;
            font-family: 'Noto Serif TC', serif;
            font-weight: 700;
            line-height: 1.2;
        }

        .slide.slide-5 .slide-content {
            color: #D1D5DB;
            font-size: 15px;
            line-height: 1.8;
            font-family: 'Noto Sans TC', sans-serif;
            font-weight: 400;
        }

        .slide.slide-5 .content-line {
            margin-bottom: 14px;
        }

        /* ===== SLIDE 6: PAYOFF ===== */
        .slide.slide-6 {
            background: linear-gradient(135deg, #162A47 0%, #1E3A5F 100%);
            justify-content: flex-start;
            padding-top: 80px;
        }

        .slide.slide-6 .slide-title {
            color: #5B9EFF;
            font-size: 42px;
            margin-bottom: 32px;
            font-family: 'Noto Serif TC', serif;
            font-weight: 700;
            line-height: 1.2;
        }

        .slide.slide-6 .slide-content {
            color: #D1D5DB;
            font-size: 15px;
            line-height: 1.8;
            font-family: 'Noto Sans TC', sans-serif;
            font-weight: 400;
        }

        .slide.slide-6 .content-line {
            margin-bottom: 12px;
        }

        .slide.slide-6 .highlight {
            color: #5B9EFF;
            font-weight: 600;
        }

        /* ===== SLIDE 7: CTA ===== */
        .slide.slide-7 {
            background: linear-gradient(135deg, #0F1F3A 0%, #1a2a4a 50%, #0F1F3A 100%);
            justify-content: flex-start;
            padding-top: 90px;
        }

        .slide.slide-7 .slide-title {
            color: #5B9EFF;
            font-size: 64px;
            margin-bottom: 40px;
            font-family: 'Noto Serif TC', serif;
            font-weight: 700;
            line-height: 1;
        }

        .slide.slide-7 .slide-content {
            color: #D1D5DB;
            font-size: 15px;
            line-height: 1.8;
            margin-bottom: 40px;
            font-family: 'Noto Sans TC', sans-serif;
            font-weight: 400;
        }

        .slide.slide-7 .content-line {
            margin-bottom: 12px;
        }

        .slide.slide-7 .cta-text {
            color: #5B9EFF;
            font-size: 16px;
            font-weight: 600;
            font-family: 'Noto Sans TC', sans-serif;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* ===== IG FRAME ELEMENTS ===== */
        .ig-header {
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 56px;
            background: #1E2330;
            display: flex;
            align-items: center;
            padding: 0 16px;
            border-bottom: 1px solid rgba(91, 158, 255, 0.08);
            z-index: 10;
            box-sizing: border-box;
        }

        .ig-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: linear-gradient(135deg, #5B9EFF, #4A90E2);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 700;
            font-size: 16px;
            margin-right: 10px;
            flex-shrink: 0;
            font-family: 'Noto Serif TC', serif;
        }

        .ig-username {
            flex: 1;
        }

        .ig-username .name {
            font-weight: 600;
            font-size: 13px;
            color: #E5E7EB;
            font-family: 'Noto Sans TC', sans-serif;
        }

        .ig-username .handle {
            font-size: 11px;
            color: #9CA3AF;
            font-family: 'Noto Sans TC', sans-serif;
        }

        .ig-menu {
            width: 24px;
            height: 24px;
            cursor: pointer;
            color: #9CA3AF;
            font-size: 18px;
        }

        .ig-footer {
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 54px;
            background: #1E2330;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 12px;
            border-top: 1px solid rgba(91, 158, 255, 0.08);
            z-index: 10;
            box-sizing: border-box;
        }

        .ig-icons {
            display: flex;
            gap: 20px;
            font-size: 18px;
            cursor: pointer;
        }

        .ig-icons span {
            color: #D1D5DB;
            transition: color 0.2s;
        }

        .ig-icons span:hover {
            color: #5B9EFF;
        }

        .ig-save {
            width: 20px;
            height: 20px;
            border: 2px solid #D1D5DB;
            cursor: pointer;
            transition: all 0.2s;
        }

        .ig-save:hover {
            border-color: #5B9EFF;
        }

        .progress-bar {
            position: absolute;
            bottom: 54px;
            left: 0;
            right: 0;
            height: 2px;
            background: rgba(91, 158, 255, 0.1);
            z-index: 5;
        }

        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #5B9EFF, #4A90E2);
            transition: width 0.5s ease;
        }

        .slide-counter {
            position: absolute;
            top: 12px;
            right: 16px;
            background: rgba(91, 158, 255, 0.15);
            color: #5B9EFF;
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 11px;
            z-index: 20;
            font-family: 'Noto Sans TC', sans-serif;
            font-weight: 600;
            border: 1px solid rgba(91, 158, 255, 0.2);
        }

        /* ===== CONTROLS ===== */
        .carousel-controls {
            position: absolute;
            bottom: 80px;
            left: 0;
            right: 0;
            display: flex;
            justify-content: space-between;
            padding: 0 20px;
            z-index: 15;
            pointer-events: none;
        }

        .carousel-arrow {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(91, 158, 255, 0.15);
            border: 1.5px solid rgba(91, 158, 255, 0.3);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: #5B9EFF;
            font-size: 18px;
            font-weight: 600;
            transition: all 0.3s ease;
            pointer-events: auto;
            user-select: none;
            font-family: 'Noto Sans TC', sans-serif;
        }

        .carousel-arrow:hover {
            background: rgba(91, 158, 255, 0.25);
            border-color: #5B9EFF;
            transform: scale(1.1);
        }

        .carousel-arrow:active {
            transform: scale(0.95);
        }

        /* ===== RESPONSIVE ===== */
        @media (max-width: 600px) {
            .carousel-container {
                max-width: 100%;
                border-radius: 0;
                aspect-ratio: auto;
                height: 100vh;
                max-height: 100vh;
            }

            .slide {
                padding: 56px 32px 70px;
            }

            .slide.slide-1 .slide-title {
                font-size: 64px;
            }

            .slide.slide-2 .slide-title,
            .slide.slide-3 .slide-title,
            .slide.slide-5 .slide-title,
            .slide.slide-6 .slide-title {
                font-size: 32px;
            }

            .slide.slide-7 .slide-title {
                font-size: 52px;
            }
        }

        /* ===== ANIMATIONS ===== */
        @keyframes fadeIn {
            from {
                opacity: 0;
            }
            to {
                opacity: 1;
            }
        }

        .slide.active {
            animation: fadeIn 0.5s ease-in-out;
        }
    </style>
</head>
<body>
    <div class="carousel-container">
        <!-- IG Header -->
        <div class="ig-header">
            <div class="ig-avatar">F</div>
            <div class="ig-username">
                <div class="name">fishtvlove</div>
                <div class="handle">打掉重練</div>
            </div>
            <div class="ig-menu">⋯</div>
        </div>

        <!-- Carousel Wrapper -->
        <div class="carousel-wrapper">
            <!-- SLIDE 1: HOOK -->
            <div class="slide slide-1 active">
                <div class="slide-title">打掉重練</div>
                <div class="slide-subtitle">沒有開發經驗的人<br>也能用 AI 做出軟體工具</div>
            </div>

            <!-- SLIDE 2: CONTEXT -->
            <div class="slide slide-2">
                <div class="slide-title">從文字產出<br>到影片生成</div>
                <div class="slide-content">
                    <div class="content-line">一開始想做 AI 文字服務</div>
                    <div class="content-line" style="margin-bottom: 20px;"></div>
                    <div class="content-line">接了顧問案後</div>
                    <div class="content-line">需求變成「圖片轉影片」</div>
                    <div class="content-line" style="margin-bottom: 20px;"></div>
                    <div class="content-line">於是開始研究怎麼讓</div>
                    <div class="content-line">Claude Code 產影片</div>
                </div>
            </div>

            <!-- SLIDE 3: BUILD #1 -->
            <div class="slide slide-3">
                <div class="slide-title">四步驟產出<br>真人影片</div>
                <div class="step">
                    <span class="step-emoji">1️⃣</span>
                    <span>產出穩定的影片腳本</span>
                </div>
                <div class="step">
                    <span class="step-emoji">2️⃣</span>
                    <span>畫出分鏡圖</span>
                </div>
                <div class="step">
                    <span class="step-emoji">3️⃣</span>
                    <span>匯入首尾幀影像</span>
                </div>
                <div class="step">
                    <span class="step-emoji">4️⃣</span>
                    <span>生成真人口型與狀態</span>
                </div>
            </div>

            <!-- SLIDE 4: BUILD #2 -->
            <div class="slide slide-4">
                <div class="slide-title">「重新造輪子」<br>不簡單</div>
                <div class="slide-content">
                    <div class="content-line">說難不難</div>
                    <div class="content-line">但也不算容易</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">需要花很多時間爬文學習</div>
                    <div class="content-line">技術名詞多到聽不懂</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">但這正是成長的過程</div>
                </div>
            </div>

            <!-- SLIDE 5: TENSION -->
            <div class="slide slide-5">
                <div class="slide-title">我選擇用<br>白話說清楚</div>
                <div class="slide-content">
                    <div class="content-line">不想用深奧名詞來炫耀</div>
                    <div class="content-line">大多數人聽不懂我在寫什麼</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">所以儘量用白話描述</div>
                    <div class="content-line">不加術語</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">只提常見模型：</div>
                    <div class="content-line">OpenAI Code、Claude Code</div>
                </div>
            </div>

            <!-- SLIDE 6: PAYOFF -->
            <div class="slide slide-6">
                <div class="slide-title">規格驅動開發<br>就是 SOP</div>
                <div class="slide-content">
                    <div class="content-line">不用學過程式開發</div>
                    <div class="content-line">只要理解「規格驅動開發」</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">參照規格 → 寫好規格</div>
                    <div class="content-line">→ 再開發</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">普通人也能做出</div>
                    <div class="content-line">更棒的「輪子」</div>
                </div>
            </div>

            <!-- SLIDE 7: CTA -->
            <div class="slide slide-7">
                <div class="slide-title">跟我一起</div>
                <div class="slide-content">
                    <div class="content-line">每天花 10-15 小時打造工具</div>
                    <div class="content-line">token 成本狂燒</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">但我找到了解決方案</div>
                    <div class="content-line" style="margin-bottom: 16px;"></div>
                    <div class="content-line">追蹤 @fishtvlove</div>
                    <div class="content-line">看我怎麼做</div>
                </div>
                <div class="cta-text">→ 追蹤</div>
            </div>
        </div>

        <!-- Progress Bar -->
        <div class="progress-bar">
            <div class="progress-fill" id="progressFill"></div>
        </div>

        <!-- Slide Counter -->
        <div class="slide-counter">
            <span id="currentSlide">1</span>/7
        </div>

        <!-- Controls -->
        <div class="carousel-controls">
            <div class="carousel-arrow" id="prevBtn">‹</div>
            <div class="carousel-arrow" id="nextBtn">›</div>
        </div>

        <!-- IG Footer -->
        <div class="ig-footer">
            <div class="ig-icons">
                <span>♥</span>
                <span>💬</span>
                <span>↗</span>
            </div>
            <div class="ig-save">📌</div>
        </div>
    </div>

    <script>
        let currentSlide = 0;
        const slides = document.querySelectorAll('.slide');
        const totalSlides = slides.length;

        function updateCarousel() {
            slides.forEach((slide, index) => {
                slide.classList.remove('active');
                if (index === currentSlide) {
                    slide.classList.add('active');
                }
            });

            document.getElementById('currentSlide').textContent = currentSlide + 1;
            const progress = ((currentSlide + 1) / totalSlides) * 100;
            document.getElementById('progressFill').style.width = progress + '%';
        }

        function nextSlide() {
            currentSlide = (currentSlide + 1) % totalSlides;
            updateCarousel();
        }

        function prevSlide() {
            currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
            updateCarousel();
        }

        document.getElementById('nextBtn').addEventListener('click', nextSlide);
        document.getElementById('prevBtn').addEventListener('click', prevSlide);

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
            if (e.key === 'ArrowRight') nextSlide();
            if (e.key === 'ArrowLeft') prevSlide();
        });

        // Initialize
        updateCarousel();
    </script>
</body>
</html>
