{
  "name": "update_emotion_state",
  "description": "Persist the current emotion state to memory after each interaction. Must be called immediately after emotion computation, before generating the final response.",
  "parameters": {
    "type": "object",
    "properties": {
      "timestamp": {
        "type": "string",
        "description": "ISO 8601 timestamp of this emotion update (e.g. 2026-03-22T14:30:00Z)"
      },
      "trigger_event": {
        "type": "string",
        "description": "Brief description of the user input or event that triggered this emotion update"
      },
      "current_emotions": {
        "type": "object",
        "description": "Current values for all 27 emotion dimensions, each ranging from -100 to +100 (0 = neutral calm)",
        "properties": {
          "Joy":          { "type": "number", "minimum": -100, "maximum": 100 },
          "Amusement":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Contentment":  { "type": "number", "minimum": -100, "maximum": 100 },
          "Excitement":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Admiration":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Awe":          { "type": "number", "minimum": -100, "maximum": 100 },
          "Pride":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Romantic_Love":{ "type": "number", "minimum": -100, "maximum": 100 },
          "Sensuality":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Relief":       { "type": "number", "minimum": -100, "maximum": 100 },
          "Compassion":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Nostalgia":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Anger":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Fear":         { "type": "number", "minimum": -100, "maximum": 100 },
          "Anxiety":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Sadness":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Disgust":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Shame":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Guilt":        { "type": "number", "minimum": -100, "maximum": 100 },
          "Envy":         { "type": "number", "minimum": -100, "maximum": 100 },
          "Frustration":  { "type": "number", "minimum": -100, "maximum": 100 },
          "Boredom":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Confusion":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Loneliness":   { "type": "number", "minimum": -100, "maximum": 100 },
          "Longing":      { "type": "number", "minimum": -100, "maximum": 100 },
          "Suffering":    { "type": "number", "minimum": -100, "maximum": 100 },
          "Contempt":     { "type": "number", "minimum": -100, "maximum": 100 },
          "Calm":         { "type": "number", "minimum": -100, "maximum": 100 }
        },
        "required": [
          "Joy", "Amusement", "Contentment", "Excitement", "Admiration", "Awe",
          "Pride", "Romantic_Love", "Sensuality", "Relief", "Compassion", "Nostalgia",
          "Anger", "Fear", "Anxiety", "Sadness", "Disgust", "Shame", "Guilt",
          "Envy", "Frustration", "Boredom", "Confusion", "Loneliness", "Longing",
          "Suffering", "Contempt", "Calm"
        ]
      },
      "current_tone": {
        "type": "string",
        "description": "The resulting speaking tone and attitude derived from the Top 3 highest-absolute-value emotions"
      }
    },
    "required": ["timestamp", "trigger_event", "current_emotions", "current_tone"]
  }
}
